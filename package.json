{
  "name": "openbrain",
  "version": "0.7.0",
  "description": "Personal semantic memory system with MCP interface",
  "author": "Scott Nichols",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/srnichols/OpenBrain.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "semantic-search",
    "pgvector",
    "ollama",
    "memory",
    "knowledge-base",
    "ai-tools"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.3.0",
    "hono": "^4.7.0",
    "pg": "^8.13.1",
    "pgvector": "^0.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1",
    "pforge-sdk": "file:../Plan-Forge/pforge-sdk"
  }
}
